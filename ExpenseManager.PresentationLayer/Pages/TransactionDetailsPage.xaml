<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseManager.PresentationLayer.Pages.TransactionDetailsPage"
             Title="Transaction Details">
    <VerticalStackLayout Padding="20" Spacing="16">

        <Label x:Name="AmountLabel" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" />

        <BoxView HeightRequest="1" Color="LightGray" />

        <VerticalStackLayout Spacing="8">
            <Label Text="Category" TextColor="Gray" FontSize="13" />
            <Label Text="{Binding Category, Converter={StaticResource EnumToDisplayName}}" FontSize="16" />
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="8">
            <Label Text="Description" TextColor="Gray" FontSize="13" />
            <Label Text="{Binding DescriptionForUI}" FontSize="16" />
        </VerticalStackLayout>
        
        <VerticalStackLayout Spacing="8">
            <Label Text="Date" TextColor="Gray" FontSize="13" />
            <Label Text="{Binding Date}" FontSize="16" />
        </VerticalStackLayout>

    </VerticalStackLayout>
</ContentPage>