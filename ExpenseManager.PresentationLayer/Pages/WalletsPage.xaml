<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ExpenseManager.PresentationLayer.ViewModels"
             xmlns:dtos="clr-namespace:ExpenseManager.BusinessLayer.Dtos;assembly=ExpenseManager.BusinessLayer"
             x:Class="ExpenseManager.PresentationLayer.Pages.WalletsPage"
             x:DataType="vm:WalletsViewModel"
             Title="My Wallets">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add" Command="{Binding AddWalletCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, Auto, *" Padding="12">
        <SearchBar Grid.Row="0"
                   Placeholder="Search by name..."
                   Text="{Binding SearchText}"
                   TextChanged="OnFilterChanged" />

        <Picker Grid.Row="1"
                Title="Sort by"
                ItemsSource="{Binding SortOptions}"
                SelectedItem="{Binding SelectedSort}"
                SelectedIndexChanged="OnFilterChanged" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Wallets}"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dtos:WalletResponse">
                    <Grid ColumnDefinitions="*, Auto" Padding="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WalletsViewModel}}, Path=LoadWalletCommand}"
                                    CommandParameter="{Binding Guid}" />
                            </VerticalStackLayout.GestureRecognizers>

                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                            <Label Text="{Binding Currency}" FontSize="14" TextColor="Gray" />
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="Delete"
                                VerticalOptions="Center"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WalletsViewModel}}, Path=DeleteWalletCommand}"
                                CommandParameter="{Binding Guid}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
</ContentPage>
