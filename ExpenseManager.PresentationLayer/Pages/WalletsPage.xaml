<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ExpenseManager.PresentationLayer.ViewModels"
             xmlns:dtos="clr-namespace:ExpenseManager.BusinessLayer.Dtos;assembly=ExpenseManager.BusinessLayer"
             x:Class="ExpenseManager.PresentationLayer.Pages.WalletsPage"
             x:DataType="vm:WalletsViewModel"
             Title="My Wallets">
    <CollectionView ItemsSource="{Binding Wallets}"
                    Margin="12"
                    SelectionMode="Single"
                    SelectedItem="{Binding SelectedWallet}">

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="dtos:WalletResponse">
                <VerticalStackLayout Padding="12" Spacing="4">
                    <Label Text="{Binding Name}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Label Text="{Binding Currency}"
                           FontSize="14"
                           TextColor="Gray" />
                    <BoxView HeightRequest="1" Color="LightGray" Margin="0,8,0,0" />
                </VerticalStackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>