<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseManager.PresentationLayer.Pages.WalletDetailsPage"
             Title="Wallet Details">
    <VerticalStackLayout>
        
        <VerticalStackLayout Padding="16" Spacing="4" BackgroundColor="#f0f0f0">
            <Label x:Name="WalletNameLabel" FontSize="20" FontAttributes="Bold" />
            <Label x:Name="WalletTotalLabel" FontSize="15" TextColor="Gray" />
        </VerticalStackLayout>

        <CollectionView x:Name="TransactionsCollection"
                        SelectionMode="Single"
                        SelectionChanged="OnTransactionSelected">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="16,10" Spacing="2">
                        <Label Text="{Binding Amount}" FontSize="15" FontAttributes="Bold" />
                        <Label Text="{Binding Category}" FontSize="13" TextColor="Gray" />
                        <Label Text="{Binding DescriptionForUI}" FontSize="14" />
                        <BoxView HeightRequest="1" Color="LightGray" Margin="0,8,0,0" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>
</ContentPage>