<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ExpenseManager.PresentationLayer.ViewModels"
             xmlns:dtos="clr-namespace:ExpenseManager.BusinessLayer.Dtos;assembly=ExpenseManager.BusinessLayer"
             x:Class="ExpenseManager.PresentationLayer.Pages.WalletDetailsPage"
             x:DataType="vm:WalletDetailsViewModel"
             Title="Wallet Details">

    <Grid>
        <Grid RowDefinitions="Auto, *" IsEnabled="{Binding IsNotBusy}">

        <VerticalStackLayout Grid.Row="0" Padding="16" Spacing="8" BackgroundColor="#f0f0f0">

            <VerticalStackLayout IsVisible="{Binding IsReadMode}" Spacing="4">
                <Label Text="{Binding Name}" FontSize="20" FontAttributes="Bold" />
                <Label Text="{Binding Currency}" FontSize="14" TextColor="Gray" />
                <Label Text="{Binding WalletTotalText}" FontSize="15" TextColor="Gray" />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsEditMode}" Spacing="6">
                <Label Text="Name" FontSize="13" TextColor="Gray" />
                <Entry Text="{Binding Name}" Placeholder="Wallet name" />
                <Label Text="Currency" FontSize="13" TextColor="Gray" />
                <Picker ItemsSource="{Binding AvailableCurrencies}"
                        SelectedItem="{Binding Currency}" />
            </VerticalStackLayout>

        </VerticalStackLayout>

        <Grid Grid.Row="1"
              IsVisible="{Binding IsExisting}"
              RowDefinitions="Auto, Auto, *">

            <SearchBar Grid.Row="0"
                       Placeholder="Search by description..."
                       Text="{Binding SearchText}"
                       TextChanged="OnFilterChanged" />

            <Picker Grid.Row="1"
                    Title="Sort by"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSort}"
                    SelectedIndexChanged="OnFilterChanged" />

            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding Transactions}"
                            SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dtos:TransactionResponse">
                        <Grid ColumnDefinitions="*, Auto" Padding="16,10">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WalletDetailsViewModel}}, Path=LoadTransactionCommand}"
                                        CommandParameter="{Binding Guid}" />
                                </VerticalStackLayout.GestureRecognizers>

                                <Label Text="{Binding Amount}" FontSize="15" FontAttributes="Bold" />
                                <Label Text="{Binding Category, Converter={StaticResource EnumToDisplayName}}"
                                       FontSize="13" TextColor="Gray" />
                                <Label Text="{Binding DescriptionForUI}" FontSize="14" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="Delete"
                                    VerticalOptions="Center"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WalletDetailsViewModel}}, Path=DeleteTransactionCommand}"
                                    CommandParameter="{Binding Guid}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>

        </Grid>

        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Grid>
</ContentPage>
